# ==================== Gmail Attachments MCP ====================
# Zo všetkých možností potrebuješ pre lokálne spustenie iba PUBLIC_URL
# a SESSION_SECRET. Ostatné sú voliteľné.

# Verejne dostupná URL servera. MUSÍ súhlasiť s OAuth redirect URI
# nakonfigurovaným v Google Cloud Console.
#   - macOS/lokálne testovanie: http://localhost:8765
#   - Orange Pi v LAN:          http://orangepi.local:8765
#   - Cez Tailscale:            https://gmail-mcp.<tail-name>.ts.net
#   - Cez Cloudflare Tunnel:    https://gmail.<tvoj-domain>
PUBLIC_URL=http://localhost:8765

# Tajný kľúč pre cookie sessions (OAuth state). Vygeneruj cez:
#   openssl rand -hex 32
SESSION_SECRET=change-me-please-run-openssl-rand-hex-32

# Voliteľná HTTP Basic auth pred web UI. Pre verejne exponovaný server
# dôrazne odporúčam zapnúť, alebo namiesto toho dať za Cloudflare Access /
# autorizáciu na úrovni reverse proxy.
UI_USERNAME=admin
# UI_PASSWORD=secret123

# Forward extract_attachment(use_ocr_pipeline=True) na tvoj OCR pipeline.
# Ak je nastavené a tool je volaný s use_ocr_pipeline=True, server pošle
# súbor sem cez multipart/form-data namiesto lokálneho parsovania.
# OCR_PIPELINE_URL=http://ocr-pipeline:8000/extract
